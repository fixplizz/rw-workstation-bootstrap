# Managed by rw-workstation-bootstrap. Do not put secrets in this file.

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"

plugins=(
  git
  docker
  docker-compose
  npm
  node
  zsh-autosuggestions
  zsh-syntax-highlighting
)

if [ -s "$ZSH/oh-my-zsh.sh" ]; then
  source "$ZSH/oh-my-zsh.sh"
fi

export EDITOR="${EDITOR:-nano}"
export PATH="$HOME/.local/bin:$HOME/bin:$HOME/.opencode/bin:$PATH"
export FZF_DEFAULT_COMMAND='fdfind --type f 2>/dev/null || fd --type f 2>/dev/null || find . -type f'

alias ll='ls -lah'
alias gs='git status --short'
alias gp='git pull --ff-only'
alias dc='docker compose'
alias opencode-workstation='bash ~/projects/rw-omniroute/rw-workstation-bootstrap/scripts/run-opencode.sh'

if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

if [ -s "$HOME/.bun/_bun" ]; then
  source "$HOME/.bun/_bun"
fi

if [ -d "$HOME/.bun/bin" ]; then
  export BUN_INSTALL="$HOME/.bun"
  export PATH="$BUN_INSTALL/bin:$PATH"
fi
